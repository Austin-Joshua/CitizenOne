# Copy to .env — never commit real secrets.
NODE_ENV=development
PORT=5000

JWT_SECRET=development-only-change-me-16chars-min
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_DAYS=7

# PUBLIC_APP_URL=https://portal.example.gov
# CORS_ORIGIN=http://localhost:5173

# PostgreSQL (omit for JSON file mode)
# DATABASE_URL=postgresql://user:pass@localhost:5432/citizen

# Production strict gate (set false only for staged demos)
# STRICT_PRODUCTION_CONFIG=true

# SMTP (required when STRICT_PRODUCTION_CONFIG=true in production)
# SMTP_HOST=smtp.example.gov
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_FROM="Citizen One <noreply@example.gov>"
# SMTP_USER=
# SMTP_PASS=

# Optional diagnostics — never in real production
# ALLOW_EMAIL_DEBUG_LINKS=false

# Stripe (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PREMIUM=

# ENABLE_HELMET_CSP=true
